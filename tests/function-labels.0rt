testcase "warning when return name differs from arg label" {
  compiles
  require compiler "value:"
  require compiler "result"
  require compiler "another:"
  require compiler "different"
  exclude compiler "fine"
}

concrete Value {
  @type call (Int) -> (Int fine:, Int value:, Int another:)
}

define Value {
  call (number) (fine, result, different) { return 1, 2, 3 }
}
