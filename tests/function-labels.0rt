testcase "warning when arg name differs from arg label" {
  compiles
  require compiler "value:"
  require compiler "number"
}

concrete Value {
  @type call (Int value:) -> (Int)
}

define Value {
  call (number) { return number }
}


testcase "no warning when arg with label is ignored" {
  compiles
  exclude compiler "value:"
}

concrete Value {
  @type call (Int value:) -> (Int)
}

define Value {
  call (_) { return 1 }
}


testcase "prefix not allowed with required labels" {
  error
  require compiler "value:"
}

unittest test {
  \ `Value.call` 123
}

concrete Value {
  @type call (Int value:) -> (Int)
}

define Value {
  call (_) { return 1 }
}


testcase "infix not allowed with required labels" {
  error
  require compiler "value1:"
  require compiler "value2:"
}

unittest test {
  \ 987 `Value.call` 123
}

concrete Value {
  @type call (Int value1:, Int value2:) -> (Int)
}

define Value {
  call (_, _) { return 1 }
}


testcase "arg labels disallowed when forwarding multiple args" {
  error
  require compiler "value1:"
  exclude compiler "value2:"
}

unittest test {
  \ Value.call2(value1: Value.call1())
}

concrete Value {
  @type call1 () -> (Int, Int)
  @type call2 (Int value1:, Int value2:) -> ()
}

define Value {
  call1 () { return 1, 2 }
  call2 (_, _) { }
}


testcase "arg labels still checked when passing multiple returns" {
  error
  require compiler "value1:"
  require compiler "value2:"
}

unittest test {
  \ Value.call2(Value.call1())
}

concrete Value {
  @type call1 () -> (Int, Int)
  @type call2 (Int value1:, Int value2:) -> ()
}

define Value {
  call1 () { return 1, 2 }
  call2 (_, _) { }
}


testcase "reusing label is allowed" {
  success
}

unittest test {
  \ Testing.checkEquals(Value.call(positive: 1, positive: 2), 3)
}

concrete Value {
  @type call (Int positive:, Int positive:) -> (Int)
}

define Value {
  call (value1, value2) { return value1+value2 }
}


testcase "return selection with labels" {
  success
}

unittest test {
  \ Testing.checkEquals(Value.call(){first:}, 1)
  \ Testing.checkEquals(Value.call(){second:}, "foo")
  \ Testing.checkEquals(Value.call(){2}, false)
}

concrete Value {
  @type call () -> (Int first:, String second:, Bool)
}

define Value {
  call () { return 1, "foo", false }
}


testcase "reusing return label is allowed" {
  success
}

unittest test {
  \ Testing.checkEquals(Value.call(){0}, 1)
  \ Testing.checkEquals(Value.call(){1}, "foo")
  \ Testing.checkEquals(Value.call(){flag:}, false)
}

concrete Value {
  @type call () -> (Int value:, String value:, Bool flag:)
}

define Value {
  call () { return 1, "foo", false }
}


testcase "reusing return label breaks selection" {
  error
  require compiler "value:"
}

unittest test {
  \ Value.call(){value:}
}

concrete Value {
  @type call () -> (Int value:, String value:, Bool flag:)
}

define Value {
  call () { return 1, "foo", false }
}


testcase "no matches for return label" {
  error
  require compiler "value:"
}

unittest test {
  \ Value.call(){value:}
}

concrete Value {
  @type call () -> ()
}

define Value {
  call () { }
}


testcase "return labels forwarded in order for multiple returns" {
  success
}

unittest test {
  Int first, String second <- Value.call2(Value.call1())
  \ Testing.checkEquals(first, 1)
  \ Testing.checkEquals(second, "foo")
}

concrete Value {
  @type call1 () -> (Int first:, String second:)
  @type call2 (Int first:, String second:) -> (Int, String)
}

define Value {
  call1 () { return 1, "foo" }
  call2 (first, second) { return first, second }
}


testcase "return label mismatch for multiple returns" {
  error
  require compiler "oops:"
  require compiler "second:"
}

unittest test {
  \ Value.call2(Value.call1())
}

concrete Value {
  @type call1 () -> (Int first:, String oops:)
  @type call2 (Int first:, String second:) -> (Int, String)
}

define Value {
  call1 () { return 1, "foo" }
  call2 (first, second) { return first, second }
}


testcase "return labels forwarded in order for single return" {
  success
}

unittest test {
  Int first, String second <- Value.call3(Value.call1(), Value.call2())
  \ Testing.checkEquals(first, 1)
  \ Testing.checkEquals(second, "foo")
}

concrete Value {
  @type call1 () -> (Int first:)
  @type call2 () -> (String second:)
  @type call3 (Int first:, String second:) -> (Int, String)
}

define Value {
  call1 () { return 1 }
  call2 () { return "foo" }
  call3 (first, second) { return first, second }
}


testcase "return label mismatch for single return" {
  error
  require compiler "oops:"
  require compiler "second:"
}

unittest test {
  \ Value.call3(Value.call1(), Value.call2())
}

concrete Value {
  @type call1 () -> (Int first:)
  @type call2 () -> (String oops:)
  @type call3 (Int first:, String second:) -> (Int, String)
}

define Value {
  call1 () { return 1 }
  call2 () { return "foo" }
  call3 (first, second) { return first, second }
}


testcase "merge with matched return label" {
  success
}

unittest test {
  \ Testing.checkEquals(Value.call(1){value:}, 1)
}

@type interface Base {
  call (Int) -> (Int value:)
}

concrete Value {
  defines Base

  @type call (Int) -> (Int value:)
}

define Value {
  call (value) { return value }
}


